
































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local folder = workspace:WaitForChild("VisualBrainrots")

-- daftar brainrot
local targets = {
    "Strawberry Elephant",
    "Dragon Cannelloni",
    "Ta Ta Ta Ta Sahur",
    "Tim Cheese",
    "Tung Tung Tung Sahur"
}

local index = 1

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "RexzHub"
gui.ResetOnSpawn = false
gui.Parent = player.PlayerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0,160,0,90)
frame.Position = UDim2.new(0.5,-80,0.75,0)
frame.BackgroundColor3 = Color3.fromRGB(20,20,30)
frame.Active = true
frame.Draggable = true
frame.Parent = gui

Instance.new("UICorner", frame)

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,25)
title.BackgroundTransparency = 1
title.Text = "Rexz Hub"
title.TextColor3 = Color3.new(1,1,1)
title.Font = Enum.Font.GothamBold
title.TextSize = 14
title.Parent = frame

local button = Instance.new("TextButton")
button.Size = UDim2.new(1,-20,0,40)
button.Position = UDim2.new(0,10,0,35)
button.Text = "TP BRAINROT"
button.BackgroundColor3 = Color3.fromRGB(150,0,255)
button.TextColor3 = Color3.new(1,1,1)
button.Font = Enum.Font.GothamBold
button.TextSize = 13
button.Parent = frame

Instance.new("UICorner", button)

-- tombol click
button.MouseButton1Click:Connect(function()

    local name = targets[index]
    local obj = folder:FindFirstChild(name)

    if obj then
        char:PivotTo(obj:GetPivot())

        local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            fireproximityprompt(prompt)
        end
    end

    -- pindah ke brainrot berikutnya
    index = index + 1
    if index > #targets then
        index = 1
    end
end)
